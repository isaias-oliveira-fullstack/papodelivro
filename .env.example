# ============================================
# Exemplo de Variáveis de Ambiente
# ============================================
# Copie este arquivo e crie:
# - .env.local (desenvolvimento)
# - .env.production (produção)
# 
# Para cada ambiente, substitua os valores de exemplo
# pelos valores reais.
# ============================================

# ============================================
# FRONT-END (client/.env.local ou .env.production)
# ============================================

# URL da API (mude conforme o ambiente)
VITE_API_URL=http://localhost:3000/api

# Supabase (se usar no cliente)
VITE_SUPABASE_URL=https://seu-projeto.supabase.co
VITE_SUPABASE_KEY=sua-chave-publica-aqui

# Modo (development | production)
VITE_MODE=development

# ============================================
# BACK-END (server/.env.local)
# ============================================

# Porta do servidor
PORT=3000

# Ambiente
NODE_ENV=development

# ============================================
# Database - Supabase
# ============================================

# URL do Supabase
SUPABASE_URL=https://seu-projeto.supabase.co

# Chave privada do Supabase (não expor!)
SUPABASE_KEY=sua-chave-privada-aqui

# URL de conexão PostgreSQL (para Sequelize)
DATABASE_URL=postgresql://postgres:seu-password@db.supabase.co:5432/postgres

# Configurações do Database
DB_HOST=aws-1-us-east-2.pooler.supabase.com
DB_PORT=6543
DB_USER=postgres.lzxperclbejfxmfztwbn
DB_PASSWORD=seu-password
DB_NAME=postgres
DB_DIALECT=postgres

# SSL para conexões seguras
DB_SSL=true
DB_SSL_REJECT_UNAUTHORIZED=false

# ============================================
# Autenticação - JWT
# ============================================

# Chave secreta para assinar tokens (MUDE PARA VALOR SEGURO!)
# Gerar: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=sua-chave-super-secreta-com-minimo-32-caracteres

# Tempo de expiração do token
JWT_EXPIRATION=7d

# ============================================
# CORS - Controle de Origens
# ============================================

# URL do front-end (para CORS)
FRONTEND_URL=http://localhost:5173

# Múltiplas origens permitidas (separadas por vírgula)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174,https://seu-dominio.com

# ============================================
# Email (Opcional - para enviar emails)
# ============================================

# Configuração SMTP
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=seu-email@gmail.com
MAIL_PASS=sua-senha-de-app-aqui
MAIL_SECURE=false
MAIL_TO=seu-email@gmail.com

# ============================================
# BACK-END (server/.env.production)
# ============================================
# Usar valores reais para produção!
# ============================================

# Porta (Vercel ignora isso, usa 3000 automaticamente)
PORT=3000

# Ambiente de produção
NODE_ENV=production

# Database - Supabase (produção)
SUPABASE_URL=https://seu-projeto-prod.supabase.co
SUPABASE_KEY=sua-chave-privada-prod
DATABASE_URL=postgresql://postgres:senha-prod@db.supabase.co:5432/postgres

# JWT - MUDE PARA VALOR SEGURO DIFERENTE
JWT_SECRET=chave-super-secreta-producao-com-minimo-32-caracteres
JWT_EXPIRATION=7d

# CORS - URLs de produção
FRONTEND_URL=https://papodelivro.vercel.app
ALLOWED_ORIGINS=https://papodelivro.vercel.app,https://www.papodelivro.com

# Email (produção)
MAIL_HOST=smtp.seuservidor.com
MAIL_PORT=587
MAIL_USER=noreply@papodelivro.com
MAIL_PASS=sua-senha-produca
MAIL_SECURE=true
MAIL_TO=suporte@papodelivro.com

# ============================================
# FRONT-END (client/.env.production)
# ============================================

# URL da API em produção
VITE_API_URL=https://papodelivro-api.vercel.app/api

# Supabase (produção)
VITE_SUPABASE_URL=https://seu-projeto-prod.supabase.co
VITE_SUPABASE_KEY=sua-chave-publica-prod

# Modo
VITE_MODE=production

# ============================================
# DICAS DE SEGURANÇA
# ============================================

# ⚠️ NUNCA comite variáveis sensíveis:
# - JWT_SECRET
# - Database URLs com senhas
# - Chaves de API
# - Passwords

# ✅ DO adicione .env* ao .gitignore:
# .env
# .env.local
# .env.*.local
# .env.production

# ✅ Para gerar chaves seguras:
# Node.js: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Python: python -c "import secrets; print(secrets.token_hex(32))"

# ✅ Use .env.example para documentar variáveis (sem valores!)

# ============================================
# COMO USAR
# ============================================

# Acesso em Node.js:
# const apiUrl = process.env.SUPABASE_URL;

# Acesso em React (Vite):
# const apiUrl = import.meta.env.VITE_API_URL;

# Acesso em TypeScript:
// const token = process.env.JWT_SECRET as string;
// const apiUrl = import.meta.env.VITE_API_URL as string;
