{
  "name": "papodelivro",
  "version": "1.0.0",
  "description": "Backend da aplicação Papo de Livro (resumos de livros, com Supabase como banco de dados principal)",
  "main": "src/server.ts",
  "scripts": {
    "dev": "cross-env NODE_ENV=development nodemon --watch src --ext ts --exec ts-node src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "cross-env NODE_ENV=production node dist/server.js",
    "start:dev": "ts-node src/server.ts",
    "test": "npm run build && jest --runInBand",
    "migrate": "sequelize db:migrate",
    "seed:prod": "dotenv -e .env.production -- sequelize-cli db:seed:all",
    "vercel-build": "tsc -p tsconfig.json"
  },
  "keywords": [],
  "author": "Isaias Oliveira",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@supabase/supabase-js": "^2.52.1",
    "bcryptjs": "^3.0.2",
    "cors": "^2.8.5",
    "cross-env": "^7.0.3",
    "dotenv": "^17.2.0",
    "express": "^5.1.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.0.2",
    "nodemailer": "^7.0.5",
    "pg": "^8.16.3",
    "slugify": "^1.6.9",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.2",
    "@types/cors": "^2.8.12",
    "@types/express": "^4.17.17",
    "@types/jest": "^29.5.4",
    "@types/jsonwebtoken": "^9.0.2",
    "@types/multer": "^1.4.7",
    "@types/node": "^20.11.2",
    "@types/pg": "^8.11.11",
    "@types/sequelize": "^4.28.20",
    "@types/supertest": "^2.0.12",
    "@types/swagger-jsdoc": "^6.0.3",
    "dotenv-cli": "^9.0.0",
    "jest": "^30.0.5",
    "nodemon": "^3.1.10",
    "sequelize": "^6.37.8",
    "sequelize-cli": "^6.6.3",
    "sqlite3": "^6.0.1",
    "supertest": "^7.1.4",
    "ts-node": "^10.9.1",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.6.2"
  }
}
